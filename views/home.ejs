<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>الرئيسية - مسابقة كأس العالم</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'home', user: user, top3: top3 }) %>
    <main class="main-content">
      <section class="page-content">

        <!-- ===== MOBILE HOME (≤860px) — leaderboard style ===== -->
        <div class="lb">

          <!-- Header -->
          <div class="lb-header">
            <div class="lb-header-bg"></div>
            <div class="lb-header-inner">
              <div style="width:40px;"></div>
              <div class="lb-header-logo">
                <img src="/logo.png" alt="شعار المسابقة" style="width:56px;height:56px;object-fit:contain;filter:drop-shadow(0 2px 8px rgba(212,175,55,0.35));">
              </div>
              <span class="lb-header-guide" onclick="window.location='/rules'">دليل التوقع</span>
            </div>
            <h1 class="lb-header-title">ترتيب المتسابقين</h1>
            <p class="lb-header-update">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              آخر تحديث قبل 3 دقائق
            </p>
          </div>

          <!-- Podium Top 3: silver(right)=order1 / gold(center)=order2 / bronze(left)=order3 -->
          <div class="lb-podium">

            <%/* --- SILVER (rank 2) --- */%>
            <% if (leaderboard.length >= 2) { %>
            <div class="lb-pod-card lb-pod-silver">
              <div class="lb-pod-crown"><span>🥈</span></div>
              <div class="lb-pod-avatar lb-pod-avatar-sm">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
              </div>
              <div class="lb-pod-badge lb-pod-badge-2">2</div>
              <div class="lb-pod-name"><%= leaderboard[1].name %></div>
              <div class="lb-pod-pts"><%= leaderboard[1].total.toLocaleString('ar-EG') %> نقطة</div>
              <div class="lb-pod-correct"><span class="lb-pod-correct-dot"></span><%= leaderboard[1].correct_predictions %> توقع صحيح</div>
            </div>
            <% } else { %>
            <div class="lb-pod-card lb-pod-silver lb-pod-empty"><span class="lb-pod-empty-text">—</span></div>
            <% } %>

            <%/* --- GOLD (rank 1) center --- */%>
            <% if (leaderboard.length >= 1) { %>
            <div class="lb-pod-card lb-pod-gold">
              <div class="lb-pod-crown lb-pod-crown-gold"><span>👑</span></div>
              <div class="lb-pod-avatar lb-pod-avatar-lg">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
              </div>
              <div class="lb-pod-badge lb-pod-badge-1">1</div>
              <div class="lb-pod-name"><%= leaderboard[0].name %></div>
              <div class="lb-pod-pts"><%= leaderboard[0].total.toLocaleString('ar-EG') %> نقطة</div>
              <div class="lb-pod-correct"><span class="lb-pod-correct-dot"></span><%= leaderboard[0].correct_predictions %> توقع صحيح</div>
            </div>
            <% } else { %>
            <div class="lb-pod-card lb-pod-gold lb-pod-empty"><span class="lb-pod-empty-text">—</span></div>
            <% } %>

            <%/* --- BRONZE (rank 3) --- */%>
            <% if (leaderboard.length >= 3) { %>
            <div class="lb-pod-card lb-pod-bronze">
              <div class="lb-pod-crown"><span>🥉</span></div>
              <div class="lb-pod-avatar lb-pod-avatar-sm">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
              </div>
              <div class="lb-pod-badge lb-pod-badge-3">3</div>
              <div class="lb-pod-name"><%= leaderboard[2].name %></div>
              <div class="lb-pod-pts"><%= leaderboard[2].total.toLocaleString('ar-EG') %> نقطة</div>
              <div class="lb-pod-correct"><span class="lb-pod-correct-dot"></span><%= leaderboard[2].correct_predictions %> توقع صحيح</div>
            </div>
            <% } else { %>
            <div class="lb-pod-card lb-pod-bronze lb-pod-empty"><span class="lb-pod-empty-text">—</span></div>
            <% } %>

          </div>

          <!-- My Rank Card -->
          <% if (userEntry) { %>
          <div class="lb-myrank">
            <div class="lb-myrank-left">
              <div class="lb-myrank-avatar">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
              </div>
              <span class="lb-myrank-label">ترتيبك الحالي</span>
              <span class="lb-myrank-num">#<%= userRank %></span>
              <span class="lb-myrank-pts"><%= userEntry.total.toLocaleString('ar-EG') %> نقطة</span>
            </div>
            <div class="lb-myrank-vr"></div>
            <div class="lb-myrank-right">
              <span class="lb-myrank-gap">
                <% if (gapToFifth > 0) { %>
                  تبعد <strong><%= gapToFifth.toLocaleString('ar-EG') %></strong> نقطة عن المركز الخامس
                <% } else if (userRank <= 5) { %>
                  أنت ضمن أفضل 5 متسابقين 🏆
                <% } else { %>
                  واصل التوقعات لترتفع في الترتيب
                <% } %>
              </span>
              <div class="lb-myrank-progress-wrap">
                <div class="lb-myrank-progress">
                  <div class="lb-myrank-bar" style="width: <%= Math.min(100, leaderboard[0] && leaderboard[0].total > 0 ? Math.round((userEntry.total / leaderboard[0].total) * 100) : 0) %>%"></div>
                </div>
                <div class="lb-myrank-labels">
                  <span>المركز <%= userRank %></span>
                  <span><%= userRank <= 5 ? 'المركز 1' : 'المركز 5' %></span>
                </div>
              </div>
            </div>
          </div>
          <% } %>

          <!-- Leaderboard List -->
          <div class="lb-list-wrap">
            <div class="lb-list-header">
              <span class="lb-lh-rank">الترتيب</span>
              <span class="lb-lh-player">المتسابق</span>
              <span class="lb-lh-pts">النقاط</span>
              <span class="lb-lh-correct">صحيح</span>
              <span class="lb-lh-move">الحركة</span>
            </div>
            <% if (leaderboard.length <= 3) { %>
            <div class="lb-empty">
              <div class="lb-empty-icon">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/></svg>
              </div>
              <p>لم يكتمل الترتيب بعد<br>سيظهر الترتيب بعد تسجيل أول نتائج المباريات</p>
            </div>
            <% } else { %>
              <% leaderboard.slice(3).forEach(function(p, i) {
                var rank = i + 4;
                var isMe = p.id === user.id;
              %>
              <div class="lb-row <%= isMe ? 'lb-row-me' : '' %>" data-rank="<%= rank %>">
                <span class="lb-row-rank"><%= rank %></span>
                <div class="lb-row-player">
                  <div class="lb-row-avatar">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                  </div>
                  <div class="lb-row-info">
                    <span class="lb-row-name"><%= p.name %></span>
                    <span class="lb-row-correct"><%= p.correct_predictions %> توقع صحيح</span>
                  </div>
                  <% if (isMe) { %><span class="lb-row-me-label">أنت</span><% } %>
                </div>
                <span class="lb-row-pts"><%= p.total.toLocaleString('ar-EG') %></span>
                <span class="lb-row-correct-num"><%= p.correct_predictions %></span>
                <span class="lb-row-move">—</span>
              </div>
            <% }); } %>
          </div>

          <!-- Upcoming Matches Carousel -->
          <div class="hm-sec">
            <div class="hm-sec-head">
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg>
              <span>المباريات القادمة</span>
            </div>
            <div class="hm-matches-scroll">
              <% if (upcomingMatches && upcomingMatches.length > 0) { %>
                <% upcomingMatches.slice(0,6).forEach(function(m) { %>
                <div class="hm-match-card">
                  <div class="hm-mc-badge"><%= m.stage || 'دوري المجموعات' %></div>
                  <div class="hm-mc-teams">
                    <div class="hm-mc-team">
                      <img src="/flags/<%= teamFlags[m.teamA] || 'unknown' %>.png" alt="<%= m.teamA %>" onerror="this.src='/flags/unknown.png'" class="hm-mc-flag">
                      <span class="hm-mc-name"><%= m.teamA %></span>
                    </div>
                    <div class="hm-mc-vs">VS</div>
                    <div class="hm-mc-team">
                      <img src="/flags/<%= teamFlags[m.teamB] || 'unknown' %>.png" alt="<%= m.teamB %>" onerror="this.src='/flags/unknown.png'" class="hm-mc-flag">
                      <span class="hm-mc-name"><%= m.teamB %></span>
                    </div>
                  </div>
                  <div class="hm-mc-time">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <%= new Date(m.start_at).toLocaleDateString('ar-SA',{weekday:'short',month:'short',day:'numeric'}) %>
                    &nbsp;·&nbsp;
                    <%= new Date(m.start_at).toLocaleTimeString('ar-EG',{hour:'2-digit',minute:'2-digit'}) %>
                  </div>
                  <a href="/predictions" class="hm-mc-btn">توقع الآن</a>
                </div>
                <% }); %>
              <% } else { %>
                <div class="hm-mc-empty">لا توجد مباريات قادمة</div>
              <% } %>
            </div>
          </div>

          <!-- Latest News -->
          <% if (typeof newsItems !== 'undefined' && newsItems && newsItems.length > 0) { %>
          <div class="hm-sec hm-sec-news">
            <div class="hm-sec-head">
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M22 3l-1.67 1.67L18.67 3 17 4.67 15.33 3l-1.66 1.67L12 3l-1.67 1.67L8.67 3 7 4.67 5.33 3 3.67 4.67 2 3v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V3z"/></svg>
              <span>آخر الأخبار</span>
            </div>
            <div class="hm-news-list">
              <% newsItems.slice(0,3).forEach(function(n) { %>
              <a href="/news" class="hm-news-item">
                <% if (n.image_path) { %>
                <img src="<%= n.image_path %>" alt="" class="hm-news-thumb" onerror="this.style.display='none'">
                <% } else { %>
                <div class="hm-news-thumb hm-news-thumb-ph">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M22 3l-1.67 1.67L18.67 3 17 4.67 15.33 3l-1.66 1.67L12 3l-1.67 1.67L8.67 3 7 4.67 5.33 3 3.67 4.67 2 3v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V3z"/></svg>
                </div>
                <% } %>
                <div class="hm-news-body">
                  <% if (n.breaking) { %><span class="hm-news-breaking">عاجل</span><% } %>
                  <span class="hm-news-title"><%= n.title %></span>
                  <span class="hm-news-time">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <%= new Date(n.created_at || Date.now()).toLocaleDateString('ar-SA',{month:'short',day:'numeric'}) %>
                  </span>
                </div>
              </a>
              <% }); %>
            </div>
            <a href="/news" class="hm-news-all">عرض جميع الأخبار</a>
          </div>
          <% } %>

          <!-- Titles Card -->
          <div class="lb-prizes" style="margin-bottom:120px;">
            <div class="lb-prizes-head">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2z"/></svg>
              الألقاب
            </div>
            <div class="lb-prizes-body">
              <div class="lb-prize">
                <div class="lb-prize-icon lb-prize-gold"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2z"/></svg></div>
                <span class="lb-prize-title">بطل التوقعات</span>
                <span class="lb-prize-amount">المركز الأول</span>
              </div>
              <div class="lb-prize-vr"></div>
              <div class="lb-prize">
                <div class="lb-prize-icon lb-prize-silver"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2z"/></svg></div>
                <span class="lb-prize-title">الوصيف</span>
                <span class="lb-prize-amount">المركز الثاني</span>
              </div>
              <div class="lb-prize-vr"></div>
              <div class="lb-prize">
                <div class="lb-prize-icon lb-prize-bronze"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2z"/></svg></div>
                <span class="lb-prize-title">الوصيف الثاني</span>
                <span class="lb-prize-amount">المركز الثالث</span>
              </div>
            </div>
          </div>

        </div>
        <!-- ===== END MOBILE HOME ===== -->

        <!-- ===== DESKTOP HOME (≥861px) ===== -->
        <div class="mh-desktop">

        <!-- Stats Bar -->
        <div class="hm-stats">
          <div class="hm-stat-card">
            <div class="hm-stat-icon hm-stat-blue">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/></svg>
            </div>
            <div class="hm-stat-info">
              <span class="hm-stat-num"><%= predictionsCount %></span>
              <span class="hm-stat-lbl">توقعاتك المسجلة</span>
            </div>
          </div>
          <div class="hm-stat-card">
            <div class="hm-stat-icon hm-stat-green">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
            </div>
            <div class="hm-stat-info">
              <span class="hm-stat-num hm-stat-pts">
                <% if (lastMatch) { %>
                  <span class="hm-stat-flags">
                    <img src="/flags/<%= teamFlags[lastMatch.teamA] || 'unknown' %>.png" alt="" class="hm-stat-flag" onerror="this.src='/flags/unknown.png'">
                    <span class="hm-stat-vs">vs</span>
                    <img src="/flags/<%= teamFlags[lastMatch.teamB] || 'unknown' %>.png" alt="" class="hm-stat-flag" onerror="this.src='/flags/unknown.png'">
                  </span>
                <% } %>
                50 points
              </span>
              <span class="hm-stat-lbl">آخر مباراة متوقعة</span>
            </div>
          </div>
          <div class="hm-stat-card">
            <div class="hm-stat-icon hm-stat-indigo">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="22" height="22"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
            <div class="hm-stat-info">
              <span class="hm-stat-num"><%= correctPredictions %></span>
              <span class="hm-stat-lbl">عدد التوقعات الصحيحة</span>
            </div>
          </div>
          <div class="hm-stat-card">
            <div class="hm-stat-icon hm-stat-red">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm0-14c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm0 10c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
            </div>
            <div class="hm-stat-info">
              <span class="hm-stat-num"><%= userRank %></span>
              <span class="hm-stat-lbl">ترتيبك الآن</span>
            </div>
          </div>
          <div class="hm-stat-card hm-stat-highlight">
            <div class="hm-stat-icon hm-stat-gold">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
            </div>
            <div class="hm-stat-info">
              <span class="hm-stat-num"><%= userPoints.toLocaleString('ar-EG') %></span>
              <span class="hm-stat-lbl">نقاطك الحالية</span>
            </div>
          </div>
        </div>

        <!-- Matches Section -->
        <div class="hm-section">
          <!-- Toolbar -->
          <div class="hm-toolbar">
            <div class="hm-toolbar-right">
              <span class="hm-toolbar-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                التوقعات القادمة والأكثر شعبية
              </span>
            </div>
            <div class="hm-toolbar-left">
              <button class="hm-view-btn active" id="hm-list-btn" onclick="hmSetView('list')" title="عرض القائمة">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
              </button>
              <button class="hm-view-btn" id="hm-grid-btn" onclick="hmSetView('grid')" title="عرض الشبكة">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              </button>
              <button class="hm-filter-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                تصفية المباريات
              </button>
            </div>
          </div>

          <!-- Matches Table -->
          <div class="hm-table-wrap" id="hm-matches-container">
            <table class="hm-table">
              <thead>
                <tr>
                  <th>المباراة</th>
                  <th>المجموعة</th>
                  <th>الوقت</th>
                  <th>التوقعات الكلية</th>
                  <th>توقع</th>
                </tr>
              </thead>
              <tbody>
                <% matches.forEach((item, idx) => { %>
                <%
                  const match = item.match || item;
                  const pred = item.prediction;
                  const locked = item.locked;
                  const totalPreds = '-';
                %>
                <tr class="hm-row <%= locked ? 'hm-row-locked' : '' %>">
                  <td>
                    <div class="hm-match-cell">
                      <div class="hm-match-team">
                        <div class="hm-match-flag">
                          <img src="/flags/<%= teamFlags[match.teamA] || 'unknown' %>.png" alt="<%= match.teamA %>" onerror="this.src='/flags/unknown.png'">
                        </div>
                        <span class="hm-match-name"><%= match.teamA %></span>
                      </div>
                      <div class="hm-vs">
                        <% if (match.actual_scoreA != null && match.actual_scoreB != null) { %>
                          <span class="hm-final-score"><%= match.actual_scoreA %> - <%= match.actual_scoreB %></span>
                        <% } else { %>
                          VS
                        <% } %>
                      </div>
                      <div class="hm-match-team hm-match-team-right">
                        <span class="hm-match-name"><%= match.teamB %></span>
                        <div class="hm-match-flag">
                          <img src="/flags/<%= teamFlags[match.teamB] || 'unknown' %>.png" alt="<%= match.teamB %>" onerror="this.src='/flags/unknown.png'">
                        </div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="hm-group-badge"><%= match.stage %></span>
                  </td>
                  <td>
                    <div class="hm-time-cell">
                      <span class="hm-time-text">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <%= new Date(match.start_at).toLocaleTimeString('ar-EG', { hour: '2-digit', minute: '2-digit' }) %>
                      </span>
                    </div>
                  </td>
                  <td>
                    <span class="hm-total-preds"><%= totalPreds.toLocaleString('ar-EG') %></span>
                  </td>
                  <td>
                    <div class="hm-pred-cell">
                      <% if (locked) { %>
                        <span class="hm-locked-badge">انتهى الوقت</span>
                      <% } else { %>
                        <form method="POST" action="/predictions" class="hm-pred-form">
                          <input type="hidden" name="matchId" value="<%= match.id %>">
                          <div class="hm-score-inputs">
                            <input type="number" name="scoreA" value="<%= pred ? pred.scoreA : '' %>" min="0" placeholder="0" required class="hm-score-input">
                            <span class="hm-score-sep">-</span>
                            <input type="number" name="scoreB" value="<%= pred ? pred.scoreB : '' %>" min="0" placeholder="0" required class="hm-score-input">
                          </div>
                          <button type="submit" class="hm-save-btn">سجل توقعك</button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% if (matches.length === 0) { %>
            <div class="hm-empty">
              <div class="hm-empty-icon">⚽</div>
              <div class="hm-empty-title">لا توجد مباريات متاحة</div>
              <div class="hm-empty-text">لم يتم نشر أي جولة بعد.</div>
            </div>
            <% } %>
          </div>
        </div>

    </div>
  </section>
    </main>
  </div>

  <script>
    function hmSetView(view) {
      const container = document.getElementById('hm-matches-container');
      const listBtn = document.getElementById('hm-list-btn');
      const gridBtn = document.getElementById('hm-grid-btn');
      if (view === 'grid') {
        container.classList.add('hm-grid-view');
        gridBtn.classList.add('active');
        listBtn.classList.remove('active');
      } else {
        container.classList.remove('hm-grid-view');
        listBtn.classList.add('active');
        gridBtn.classList.remove('active');
      }
    }
  </script>
<%- include('partials/mobile-nav', { active: 'home' }) %>
</body>
</html>
